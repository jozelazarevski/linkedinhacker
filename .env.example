# ─────────────────────────────────────────────────────────────────────────────
# LinkedIn Growth Studio — environment configuration
# Copy this file to `.env.local` and fill in your real values.
# NEVER commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── LinkedIn OAuth (from https://www.linkedin.com/developers/apps) ──
# 1. Create an app, then add the products:
#      - "Sign In with LinkedIn using OpenID Connect"  -> openid, profile, email
#      - "Share on LinkedIn"                           -> w_member_social
# 2. Under Auth, add this exact Authorized redirect URL:
#      http://localhost:3000/api/auth/callback
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/callback

# OAuth scopes (space-separated). These are the only scopes LinkedIn grants
# for personal member posting. Do not request scopes you weren't approved for.
LINKEDIN_SCOPES=openid profile email w_member_social

# LinkedIn versioned APIs require a version header in YYYYMM form.
# Use a recent month that your app has access to.
LINKEDIN_API_VERSION=202401

# ── Session security ──
# Used to sign the session cookie. Generate one with:  openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# ── AI drafting (Anthropic) — optional but recommended ──
# Get a key at https://console.anthropic.com/. If unset, AI drafting is disabled
# and the rest of the app still works.
# The app also accepts the aliases CLAUDE_API / Claude_API / ANTHROPIC_AUTH_TOKEN.
ANTHROPIC_API_KEY=

# Base URL the app runs at (used to build absolute OAuth redirect URLs).
APP_BASE_URL=http://localhost:3000

# ── Deployment (optional) ──
# Protects the /api/cron/publish endpoint used by Vercel Cron to publish due
# posts. Generate with: openssl rand -hex 32
CRON_SECRET=

# ── Database ──
# Production / Vercel: use a hosted libSQL (Turso) database so data persists
# and is shared across all serverless instances. Create one free at
# https://turso.tech (`turso db create` + `turso db tokens create`).
# When TURSO_DATABASE_URL is set, the app uses it; otherwise it falls back to a
# local SQLite file (great for local dev, NOT durable on Vercel).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local-only: override the embedded SQLite file location (used when
# TURSO_DATABASE_URL is unset). On a VPS with a persistent disk you can point
# this at a mounted volume, e.g. /data/studio.db.
# DATABASE_PATH=
