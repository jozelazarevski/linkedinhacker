# Copy to .env (gitignored) and fill in.

# Your Anthropic API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides:
# Default model. Opus 4.8 is the most capable; set to claude-sonnet-4-6 for
# faster/cheaper bulk rewriting.
# HUMANIZER_MODEL=claude-opus-4-8

# Where the SQLite store lives (default: ~/.humanizer/humanizer.db)
# HUMANIZER_DB=/path/to/humanizer.db
